{
  "name": "automated-business-website-generator",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js CLI that generates business websites from Excel, fills content via Groq, deploys to Vercel, and writes URLs back to Excel.",
  "main": "src/index.js",
  "workspaces": [
    "global-website/*"
  ],
  "bin": {
    "bizsitegen": "src/index.js"
  },
  "scripts": {
    "run": "node src/index.js run",
    "status": "node src/index.js status",
    "report": "node src/index.js report",
    "dummy": "powershell -ExecutionPolicy Bypass -File scripts/generate-dummy.ps1",
    "dev:ws": "npm run dev -ws --if-present",
    "dev:all": "node scripts/dev-all.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^11.0.0",
    "dotenv": "^16.0.0",
    "groq-sdk": "^0.5.0",
    "exceljs": "^4.4.0"
  }
}
