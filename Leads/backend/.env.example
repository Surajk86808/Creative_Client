# =========================
# Repo-root environment file
# =========================
#
# Copy this file to `.env` in the repo root, then run:
# - Lead finder (scrape): `python lead_finder/run.py ...`
# - Website builder: `node website-builder/src/index.js ...`
#
# Notes:
# - Any relative paths below are treated as relative to the repo root.
# - Keep secrets in `.env` only (never commit `.env`).

# -------------------------
# Shared (used by both)
# -------------------------
# Required for:
# - website-builder AI website copy generation
# - email_sender generated outreach emails
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# Optional task-specific keys
NVIDIA_SCORING_API_KEY=
NVIDIA_EMAIL_API_KEY=
NVIDIA_GUARD_API_KEY=
NVIDIA_WEBSITE_API_KEY=

# Models
NVIDIA_PRIMARY_MODEL=mistral-nemotron
NVIDIA_FALLBACK_MODEL=nemotron-mini-4b-instruct
NVIDIA_EMAIL_MODEL=mistral-large-3-675b-instruct-2512
NVIDIA_LLAMA_GUARD_MODEL=llama-guard-4-12b
NVIDIA_WEBSITE_MODEL=mistral-nemotron
NVIDIA_PII_MODEL=gliner-pii

# -------------------------
# Website Builder (central app)
# -------------------------
# Base URL of the single deployed Next.js app.
# Example: https://demo.nexviatech.online
CENTRAL_SITE_BASE_URL=

# Demo lifetime in days before cleanup marks a site inactive.
SITE_TTL_DAYS=3

# Optional override for the central data file.
SITES_JSON_FILE=./data/sites.json

# Where generated websites + reports are stored
OUTPUT_DIR=./output

# --- Optional: auto-push generated code under OUTPUT_DIR to a separate GitHub repo ---
# Create an empty GitHub repo, then set remote URL here.
# Example (SSH): git@github.com:YOUR_USER/YOUR_OUTPUT_REPO.git
# Example (HTTPS): https://github.com/YOUR_USER/YOUR_OUTPUT_REPO.git
# OUTPUT_GIT_REMOTE=
# OUTPUT_GIT_BRANCH=main
# OUTPUT_GIT_PUSH=true
#
# If true, deletes ONLY the generated shop folder after a successful push.
# (Excel like `leads.xlsx` stays local because it is not inside the shop folder.)
# OUTPUT_GIT_DELETE_LOCAL_AFTER_PUSH=false
#
# Optional (repo-local git identity for the output repo)
# OUTPUT_GIT_USER_NAME=output-bot
# OUTPUT_GIT_USER_EMAIL=output-bot@local

# Website-builder SQLite DB (processed shops)
DB_FILE=./data/bizsitegen.sqlite

# Input Excel folder (optional; used only when not using JSON leads)
LEADS_DIR=./website-builder/leads

# Templates folder
WEBSITES_DIR=./website-builder/global-website

# Template matcher map + logs (optional overrides)
CATEGORY_MAP_FILE=./website-builder/category-map.json
ERRORS_LOG=./website-builder/errors.log

# -------------------------
# Lead Finder / Email Sender
# -------------------------
# Required for sending outreach emails
EMAIL_SMTP_HOST=smtp.zoho.in
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURITY=ssl
EMAIL_SMTP_USER=
EMAIL_HOST_PASSWORD=

# Optional email-sender branding
AGENCY_NAME=
AGENCY_WEBSITE=
SENDER_NAME=
SENDER_PHONE=
EMAIL_SIGNATURE=

# Optional email-sender advanced settings (with defaults shown)
# EMAIL_UNSUBSCRIBE_TEXT="To opt out, reply STOP."
# EMAIL_SUPPRESSION_LIST_PATH=public/email_status/suppression_list.txt
# EMAIL_BLOCKED_DOMAINS=
# MAX_PER_HOUR=50
# MAX_PER_DAY=200
# MAX_FAILED_ATTEMPTS_PER_LEAD=3
# FAILED_RETRY_COOLDOWN_HOURS=24

# -------------------------
# WhatsApp Checker
# -------------------------
WHATSAPP_DEFAULT_COUNTRY_CODE=91
WHATSAPP_REQUEST_DELAY=2.0
